# OmniSMS Linux 端口配置示例
# 复制到 /etc/omnisms/omnisms.conf 后修改

# AT 串口(建议用 /dev/serial/by-id/ 下的稳定路径，ttyUSB 序号重启会漂移)
driver = generic-3gpp
device = /dev/ttyUSB2
baud = 115200
poll_interval_ms = 3000

# 如果设备由系统 ModemManager 管理，改用以下配置，不要同时占用 AT 串口：
# driver = modemmanager
# device = auto
# 多个 modem 并存时，device 必须填写 mmcli -L 显示的数字 ID 或完整 D-Bus 对象路径。
# baud 在 ModemManager 后端中会被忽略。

# 本机号码(可选)：推送内容中区分多设备
receiver = +8613800138000

# 管理员短信命令：仅该号码可发送 SMS:号码:内容 或 RESET。
# Linux 的 RESET 会重启模组并以非零状态退出，由 systemd/procd 重拉服务，不重启整台主机。
adminPhone = +8613800138000

# ===== Web 管理界面（托管仓库共享 webui） =====
# 建议通过反向代理/Tailscale 暴露，直接公网监听前务必改强密码。
web_listen_address = 127.0.0.1
web_port = 8080
web_asset_root = /usr/share/omnisms/webui
web_username = admin
web_password = change-me

# 来电提醒：沿用短信规则、邮件和推送通道；同一通电话只通知一次
callNotifyEnabled = 1

# ===== 推送通道(最多 5 个：push0* ~ push4*) =====
# 键名与固件配置导出一致，设备"导出配置"里的 push 段可直接粘贴。
# type: 1=POST JSON  2=Bark  3=GET  4=钉钉  5=PushPlus  6=Server酱
#       7=自定义模板  8=飞书  9=Gotify  10=Telegram
push0en = 1
push0type = 1
push0name = webhook
push0url = https://example.com/sms-hook

# 例：Bark
# push1en = 1
# push1type = 2
# push1name = iPhone
# push1k1 = <Bark Device Key>

# 例：Telegram
# push2en = 1
# push2type = 10
# push2k1 = <Chat ID>
# push2k2 = <Bot Token>

# 例：钉钉加签机器人
# push3en = 1
# push3type = 4
# push3url = https://oapi.dingtalk.com/robot/send?access_token=...
# push3k1 = SEC...

# 例：自定义模板(push4body 单行 JSON，支持 {sender} {receiver} {message} {timestamp})
# push4en = 1
# push4type = 7
# push4url = https://example.com/custom
# push4body = {"from":"{sender}","text":"{message}"}

# 可选：黑名单(每行一个号码)与转发规则(与固件同格式)
# blacklist_file = /etc/omnisms/blacklist.txt
# rules_file = /etc/omnisms/rules.txt

# ===== 邮件(键名与固件导出一致；465=SMTPS，其他端口 STARTTLS) =====
# emailEnabled = 1
# smtpServer = smtp.example.com
# smtpPort = 465
# smtpUser = bot@example.com
# smtpPass = <授权码>
# smtpSendTo = me@example.com

# ===== 收件箱持久化(JSONL 追加，一行一条) =====
# inbox_file = /var/lib/omnisms/inbox.jsonl
