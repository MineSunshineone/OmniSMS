<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/omni_inset" />
            <stroke android:width="1dp" android:color="@color/omni_amber_dim" />
            <corners android:radius="@dimen/omni_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/omni_canvas_soft" />
            <stroke android:width="1dp" android:color="@color/omni_hairline_strong" />
            <corners android:radius="@dimen/omni_radius" />
        </shape>
    </item>
</selector>
